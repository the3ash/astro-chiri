{
  "name": "astro-chiri",
  "type": "module",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "tsx scripts/update-link-metadata.ts && astro dev",
    "build": "pnpm run typecheck && tsx scripts/update-link-metadata.ts && astro build",
    "typecheck": "pnpm run typecheck:ts && astro check",
    "typecheck:ts": "tsc --noEmit",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "new": "tsx scripts/new-post.ts",
    "update-link-metadata": "tsx scripts/update-link-metadata.ts",
    "update-theme": "tsx scripts/update-theme.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.4.6",
    "astro-og-canvas": "^0.11.1",
    "canvaskit-wasm": "^0.41.1",
    "feed": "^5.2.1",
    "katex": "^0.17.0",
    "markdown-it": "^14.3.0",
    "mdast-util-to-string": "^4.0.0",
    "node-html-parser": "^8.0.0",
    "reading-time": "^1.5.0",
    "rehype-katex": "^7.0.1",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.35.3",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/sanitize-html": "^2.16.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
